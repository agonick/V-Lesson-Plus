{
  "name": "v-lesson-plus",
  "version": "1.0.0",
  "private": true,
  "description": "V-Lesson Plus Chrome extension",
  "scripts": {
    "build": "npm run build:logic && npm run build:content && npm run build:popup && tsc --noEmit",
    "build:logic": "esbuild src/logic.ts --bundle --outfile=dist/logic.js --platform=browser --format=cjs",
    "build:content": "esbuild src/content.ts --bundle --outfile=dist/content.js --platform=browser",
    "build:popup": "esbuild src/popup.ts --bundle --outfile=dist/popup-bundled.js --platform=browser",
    "build:watch": "tsc --watch",
    "test": "node --test",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/chrome": "^0.1.39",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  }
}
