{
  "name": "v-lesson-plus",
  "version": "1.0.0",
  "private": true,
  "author": "Agostino Nicotra <agonick-dev@proton.me>",
  "license": "GPL-3.0-only",
  "description": "V-Lesson Plus Chrome extension",
  "repository": {
    "type": "git",
    "url": "https://github.com/agonick/v-lesson-plus.git"
  },
  "bugs": {
    "url": "https://github.com/agonick/v-lesson-plus/issues",
    "email": "agonick-dev@proton.me"
  },
  "homepage": "https://github.com/agonick/v-lesson-plus#readme",
  "scripts": {
    "build": "npm run build:logic && npm run build:content && npm run build:popup && tsc --noEmit",
    "build:logic": "esbuild src/logic.ts --bundle --outfile=dist/logic.js --platform=browser --format=cjs",
    "build:content": "esbuild src/content.ts --bundle --outfile=dist/content.js --platform=browser",
    "build:popup": "esbuild src/popup.ts --bundle --outfile=dist/popup-bundled.js --platform=browser",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/chrome": "^0.1.39",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^1.6.1"
  }
}
