{
  "manifest_version": 3,
  "name": "V-Lesson Plus",
  "version": "1.0.0",
  "description": "An unofficial Chrome extension for enhancing Uninettuno University lessons.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "V-Lesson Plus",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.uninettunouniversity.net/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
